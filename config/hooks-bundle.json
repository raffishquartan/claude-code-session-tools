{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ccst hooks run session-tag",
            "timeout": 5,
            "statusMessage": "Writing session tag file..."
          },
          {
            "type": "command",
            "command": "ccst hooks run messaging-deliver",
            "timeout": 10,
            "statusMessage": "Delivering inter-session messages..."
          },
          {
            "type": "command",
            "command": "ccst hooks run catchup",
            "timeout": 10,
            "statusMessage": "Reconciling scheduled-task catch-up..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ccst hooks run last-screenshot",
            "timeout": 5,
            "statusMessage": "Resolving latest screenshot for >lss..."
          },
          {
            "type": "command",
            "command": "ccst hooks run messaging-deliver",
            "timeout": 10,
            "statusMessage": "Checking for new inter-session messages..."
          },
          {
            "type": "command",
            "command": "ccst hooks run catchup",
            "timeout": 10,
            "statusMessage": "Surfacing scheduled-task catch-up..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ccst hooks run marker-allow",
            "timeout": 5,
            "statusMessage": "Checking for skill-marker touch..."
          },
          {
            "type": "command",
            "command": "ccst hooks run bash-security-review",
            "timeout": 30,
            "statusMessage": "Reviewing shell command for security risks..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "ccst hooks run confirm-8digit",
            "timeout": 10,
            "statusMessage": "Checking 8-digit confirmation gate..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ccst hooks run after-response",
            "timeout": 10,
            "statusMessage": "Recording session activity..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "ccst hooks run worklog-guard",
            "timeout": 5,
            "statusMessage": "Checking WORKLOG.md freshness..."
          }
        ]
      }
    ]
  }
}
